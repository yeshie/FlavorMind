rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && request.auth.token.admin == true; }
    function isOwner(ownerId) { return signedIn() && request.auth.uid == ownerId; }
    function hasPublishStatus(data) {
      return data != null && data.keys().hasAny(["publishStatus"]);
    }
    function isRecipeApprovedData(data) {
      return data != null && (data.publishStatus == "approved" || !hasPublishStatus(data));
    }
    function toInt(value) {
      return value is int ? value : 0;
    }
    function recipeDoc(recipeId) {
      return get(/databases/$(database)/documents/recipes/$(recipeId));
    }

    match /recipes/{recipeId} {
      allow read: if isRecipeApprovedData(resource.data)
                  || isOwner(resource.data.ownerId)
                  || isAdmin();

      allow create: if signedIn()
                    && request.resource.data.ownerId == request.auth.uid
                    && (request.resource.data.publishStatus == "draft"
                        || request.resource.data.publishStatus == "pending");

      allow update: if isAdmin()
                    || (isOwner(resource.data.ownerId)
                        && (
                          request.resource.data.publishStatus == resource.data.publishStatus
                          || (
                            request.resource.data.publishStatus == "pending"
                            && (resource.data.publishStatus == "draft"
                                || resource.data.publishStatus == "rejected")
                          )
                        ))
                    || (signedIn()
                        && (resource.data.publishStatus == "approved"
                            || isOwner(resource.data.ownerId))
                        && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(["rating", "feedbackCount", "updatedAt"]))
                    || (isRecipeApprovedData(resource.data)
                        && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(["views", "updatedAt"]));

      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    match /recipes/{recipeId}/feedback/{feedbackId} {
      allow read: if isRecipeApprovedData(recipeDoc(recipeId).data)
                  || isOwner(recipeDoc(recipeId).data.ownerId)
                  || isAdmin();

      allow create: if signedIn()
                    && (isRecipeApprovedData(recipeDoc(recipeId).data)
                        || isOwner(recipeDoc(recipeId).data.ownerId)
                        || isAdmin());

      allow update, delete: if isAdmin()
                            || (signedIn() && resource.data.userId == request.auth.uid)
                            || (signedIn() && isOwner(recipeDoc(recipeId).data.ownerId));
    }

    match /cookbooks/{cookbookId} {
      allow read: if resource.data.publishStatus == "approved"
                  || isOwner(resource.data.ownerId)
                  || isAdmin();

      allow create: if signedIn()
                    && request.resource.data.ownerId == request.auth.uid;

      allow update: if isAdmin()
                    || (isOwner(resource.data.ownerId)
                        && request.resource.data.publishStatus == resource.data.publishStatus);

      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    match /users/{uid}/savedRecipes/{savedId} {
      allow read, write: if request.auth.uid == uid;
    }

    match /users/{uid}/savedCookbooks/{savedId} {
      allow read, write: if request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, write: if request.auth.uid == uid || isAdmin();
    }

    match /users/{uid}/feedback/{feedbackId} {
      allow read, write: if request.auth.uid == uid || isAdmin();
    }

    match /ingredient_adaptations/{adaptationId} {
      allow read, update: if isAdmin();
    }

    match /ingredient_guides/{guideId} {
      allow read, update: if isAdmin();
    }
  }
}
